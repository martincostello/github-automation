{
  "name": "github-automation",
  "version": "4.3.4",
  "private": true,
  "description": "GitHub automation",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write eslint.config.mjs src/**/*.ts tests/**/*.ts",
    "format-check": "prettier --check eslint.config.mjs src/**/*.ts tests/**/*.ts",
    "generate": "npm run build && npm run package",
    "lint": "eslint src/**/*.ts --fix",
    "package": "npm run package:dotnet-release && npm run package:dotnet-upgrade-report && npm run package:dotnet-version-report && npm run package:get-dotnet-repos && npm run package:get-github-token && npm run package:get-rebase-repos && npm run package:get-sdk-repos && npm run package:is-dotnet-change-available",
    "package:dotnet-release": "node esbuild.config.mjs dotnet-release",
    "package:dotnet-upgrade-report": "node esbuild.config.mjs dotnet-upgrade-report",
    "package:dotnet-version-report": "node esbuild.config.mjs dotnet-version-report",
    "package:get-dotnet-repos": "node esbuild.config.mjs get-dotnet-repos",
    "package:get-github-token": "node esbuild.config.mjs get-github-token",
    "package:get-rebase-repos": "node esbuild.config.mjs get-rebase-repos",
    "package:get-sdk-repos": "node esbuild.config.mjs get-sdk-repos",
    "package:is-dotnet-change-available": "node esbuild.config.mjs is-dotnet-change-available",
    "test": "vitest run",
    "publish": "npm run format && npm run lint && npm run generate",
    "all": "npm run publish && npm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/martincostello/github-automation.git"
  },
  "keywords": [
    "actions",
    "git",
    "github"
  ],
  "author": {
    "name": "Martin Costello",
    "url": "https://martincostello.com/"
  },
  "engines": {
    "node": ">=24.0.0"
  },
  "license": "Apache-2.0",
  "bugs": {
    "url": "https://github.com/martincostello/github-automation/issues"
  },
  "homepage": "https://github.com/martincostello/github-automation#readme",
  "dependencies": {
    "@actions/core": "3.0.1",
    "@actions/exec": "3.0.0",
    "@actions/github": "9.1.1",
    "@actions/io": "3.0.2",
    "@octokit/plugin-paginate-rest": "14.0.0",
    "@octokit/plugin-rest-endpoint-methods": "17.0.0",
    "fast-xml-parser": "5.9.3",
    "undici": "8.7.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "3.3.6",
    "@eslint/js": "10.0.1",
    "@stylistic/eslint-plugin": "5.10.0",
    "@types/node": "24.13.3",
    "@typescript-eslint/eslint-plugin": "8.63.0",
    "@typescript-eslint/parser": "8.63.0",
    "@vitest/coverage-v8": "4.1.10",
    "@vitest/eslint-plugin": "1.6.22",
    "esbuild": "0.28.1",
    "eslint": "10.6.0",
    "eslint-plugin-github": "6.1.1",
    "eslint-plugin-prettier": "5.5.6",
    "globals": "17.7.0",
    "prettier": "3.9.5",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  },
  "prettier": {
    "arrowParens": "always",
    "bracketSpacing": true,
    "printWidth": 140,
    "quoteProps": "consistent",
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "useTabs": false
  }
}
